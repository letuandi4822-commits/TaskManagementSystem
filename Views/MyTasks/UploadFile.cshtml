
@model TaskManagementSystem.ViewModel.UploadTaskFileViewModel

<form asp-action="UploadFile"
      method="post"
      enctype="multipart/form-data">

    <input asp-for="TaskId" type="hidden" />

    <input asp-for="File" type="file" />

    <button class="btn btn-primary">
        Upload
    </button>
    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel

    </a>
</form>
